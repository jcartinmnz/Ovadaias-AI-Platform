# ===== Database (Neon or any Postgres) =====
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Opcional: si usas Neon con connection pooling
# NEON_DATABASE_URL=postgres://...

# ===== OpenAI (captions + prompts de imagen) =====
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ===== Gemini (nano-banana para imágenes) =====
AI_INTEGRATIONS_GEMINI_API_KEY=...
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ===== Clerk (auth) =====
CLERK_SECRET_KEY=sk_live_...
# Si quieres probar sin login (desarrollo):
# DEV_AUTH_BYPASS=true

# ===== Runtime =====
NODE_ENV=production
LOG_LEVEL=info

# ===== Frontend (ovadaias) =====
# PORT y BASE_PATH son REQUERIDOS por vite.config.ts
PORT=5173
BASE_PATH=/

# ===== API server =====
# Puerto del api-server (lee `PORT` al correr; usa uno distinto del front)
# API_PORT=3000   (si defines PORT para api-server en otra shell)

# ===== WhatsApp / Evolution (opcional, solo si usas el módulo) =====
# EVOLUTION_BASE_URL=
# EVOLUTION_API_KEY=
# EVOLUTION_INSTANCE=
# WHATSAPP_WEBHOOK_SECRET=

# ===== Email / SMTP (opcional) =====
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=
# EMAIL_TO=
